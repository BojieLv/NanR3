<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/screenBackground"
  android:fillViewport="true"
  android:padding="16dp"
  app:layout_behavior="@string/appbar_scrolling_view_behavior"
  tools:context=".MainActivity"
  tools:showIn="@layout/activity_main">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="88dp">

    <TextView
      android:id="@+id/status"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/bg_status_panel"
      android:lineSpacingExtra="3dp"
      android:minHeight="96dp"
      android:padding="18dp"
      android:text="@string/this_is_the_status"
      android:textColor="@color/statusText"
      android:textSize="16sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/bg_card"
      android:orientation="vertical"
      android:padding="16dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <CheckBox
          android:id="@+id/haveSession"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:clickable="false"
          android:focusable="false"
          android:text="@string/have_session"
          android:textColor="@color/textPrimary"
          android:textStyle="bold" />

        <Button
          android:id="@+id/statusbtn"
          style="@style/Widget.Nan.SecondaryButton"
          android:layout_width="wrap_content"
          android:layout_height="44dp"
          android:text="@string/capabilities" />
      </LinearLayout>

      <TextView
        style="@style/Widget.Nan.FieldLabel"
        android:text="@string/mac" />

      <EditText
        android:id="@+id/macAddress"
        style="@style/Widget.Nan.ValueField"
        android:hint="@string/mac"
        android:inputType="text"
        android:text="@string/mac" />

      <TextView
        style="@style/Widget.Nan.FieldLabel"
        android:text="@string/other_mac" />

      <EditText
        android:id="@+id/otherMac"
        style="@style/Widget.Nan.ValueField"
        android:hint="@string/other_mac"
        android:inputType="text"
        android:text="@string/other_mac" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/bg_card"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/discovery"
        android:textColor="@color/textPrimary"
        android:textSize="17sp"
        android:textStyle="bold" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
          android:id="@+id/publishButton"
          style="@style/Widget.Nan.PrimaryButton"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_marginEnd="8dp"
          android:layout_weight="1"
          android:text="@string/publish" />

        <Button
          android:id="@+id/subscribeButton"
          style="@style/Widget.Nan.PrimaryButton"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_marginStart="8dp"
          android:layout_weight="1"
          android:text="@string/subscribe" />
      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
          android:id="@+id/responderButton"
          style="@style/Widget.Nan.SecondaryButton"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_marginEnd="8dp"
          android:layout_weight="1"
          android:enabled="false"
          android:text="@string/responder"
          android:visibility="visible" />

        <Button
          android:id="@+id/initiatorButton"
          style="@style/Widget.Nan.SecondaryButton"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_marginStart="8dp"
          android:layout_weight="1"
          android:enabled="false"
          android:text="@string/initiator"
          android:visibility="visible" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/bg_card"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/transfer"
        android:textColor="@color/textPrimary"
        android:textSize="17sp"
        android:textStyle="bold" />

      <TextView
        style="@style/Widget.Nan.FieldLabel"
        android:text="@string/ipv6_addr" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
          android:id="@+id/IPv6text"
          style="@style/Widget.Nan.ValueField"
          android:layout_width="0dp"
          android:layout_weight="1"
          android:hint="@string/ipv6_address"
          android:importantForAutofill="no"
          android:inputType="text" />

        <Button
          android:id="@+id/sendbtn"
          style="@style/Widget.Nan.PrimaryButton"
          android:layout_width="112dp"
          android:layout_height="48dp"
          android:layout_marginStart="10dp"
          android:text="@string/send_file" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/bg_card"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/messaging"
        android:textColor="@color/textPrimary"
        android:textSize="17sp"
        android:textStyle="bold" />

      <EditText
        android:id="@+id/msgtext"
        style="@style/Widget.Nan.ValueField"
        android:layout_marginTop="12dp"
        android:hint="@string/messagetosend"
        android:importantForAutofill="no"
        android:inputType="text" />
    </LinearLayout>
  </LinearLayout>
</androidx.core.widget.NestedScrollView>
